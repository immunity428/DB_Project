<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>ジャンル詳細</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="page">
    <h1>ジャンル詳細</h1>

    <div class="detail-card">
        <p><strong>ジャンル:</strong> <%= genre.genre_name || '-' %></p>
    </div>

    <h2>関連書籍</h2>
    <table>
        <tr>
            <th>書籍名</th>
            <th>出版年</th>
            <th>状態</th>
        </tr>
        <% books.forEach(book=>{ %>
        <tr>
            <td><%= book.title || '-' %></td>
            <td><%= book.publish_year || '-' %></td>
            <td><%= book.action || '-' %></td>
        </tr>
        <% }) %>
    </table>

    <div class="back-area">
        <a href="/genres" class="back-button">ジャンル一覧へ戻る</a>
    </div>
</div>
</body>
</html>
